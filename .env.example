# Local development environment — copy to .env and adjust as needed.
# These values target LocalStack running via docker-compose.

# Resource names (must match docker-compose init and template.yaml defaults)
SIMULATION_QUEUE_NAME=simulation-queue
RESULTS_QUEUE_NAME=sim-results
SIM_TABLE_NAME=simc-cloud

# LocalStack endpoint — used by the Go AWS SDK running on the host.
# SAM local invoke overrides this to host.docker.internal (see Taskfile).
AWS_ENDPOINT_URL=http://localhost:4566

# Dummy credentials for LocalStack (not real AWS)
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
